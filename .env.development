# 资源公共路径,需要以 /开头和结尾
VITE_PUBLIC_PATH = /

# 本地开发代理，可以解决跨域及多地址代理
# 如果接口地址匹配到，则会转发到http://10.16.19.51:30000，防止本地出现跨域问题
# 可以有多个，注意多个不能换行，否则代理将会失效
# VITE_PROXY = [["/dev","http://10.0.0.56:25001"]]


# 是否删除Console.log
VITE_DROP_CONSOLE = false

# 打包是否压缩图片
VITE_USE_IMAGEMIN= false

# 接口地址
# 如果没有跨域问题，直接在这里配置即可

#VITE_GLOB_API_URL=/dev
VITE_GLOB_API_URL='https://lydcdev.lstech.com'

# WebSocket基础地址
VITE_GLOB_WEBSOCKET_URL='wss://lydcdev.lstech.com/api/message'

# 接口地址前缀，有些系统所有接口地址都有前缀，可以在这里统一加，方便切换
VITE_GLOB_API_URL_PREFIX=

# LYDC系统的运行环境
VITE_GLOB_LYDC_RUN_ENV = 'DEV'

# SVG图标库
VITE_APP_FONT_URL_LOCAL = '//at.alicdn.com/t/c/font_4663082_cp7arqcw4re.js'

# 网站标题 ，开发平台配置优先级大于前端配置
VITE_GLOB_APP_TITLE = 'DEV-DC Manage System'